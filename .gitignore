# --- Lean-import guards for reference/ (the read-only legacy source) ---
# These mirror what the source-only import excluded; keep them out if re-imported or built.
reference/**/packages/
reference/**/bin/
reference/**/obj/
reference/**/.vs/
reference/**/build/
reference/**/dist/
*.sdf
*.suo
*.user
*.pdb
*.opensdf
*.ncb

# Vendor installers (large binaries, not source)
reference/ThirdParty/*.exe

# --- .NET build output & artifacts (AmetekWatch solution) ---
bin/
obj/
dist/
*.user

# Local SQLite runtime store written by the sweep host (not source).
ametek-watch.db
*.db-shm
*.db-wal

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*~
*.swp
.idea/
.vscode/
